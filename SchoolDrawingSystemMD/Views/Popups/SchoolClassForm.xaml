<?xml version="1.0" encoding="utf-8" ?>
<mopups:PopupPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups"
    xmlns:viewModels="clr-namespace:SchoolDrawingSystemMD.ViewModels"
    x:Class="SchoolDrawingSystemMD.Views.Popups.SchoolClassForm"
    x:DataType="viewModels:SchoolClassFormViewModel"
    x:Name="SchoolClassFormPopup"
    BackgroundColor="#CC000000">

    <Border BackgroundColor="#1a1a1a" 
            Stroke="#333333"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 12"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="320"
            Padding="25">

        <VerticalStackLayout Spacing="18">

            <Label x:Name="FormTitle"
                   Text="DODAJ KLASĘ"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="White"
                   CharacterSpacing="2"
                   HorizontalOptions="Center"
                   Margin="0,0,0,5" />

            <Entry x:Name="NameEntry"
                   Placeholder="Nazwa klasy (np. 1A)"
                   PlaceholderColor="#888888"
                   TextColor="White"
                   BackgroundColor="#252525"
                   HeightRequest="45"
                   Text="{Binding ClassInfo.Name}"/>

            <Button x:Name="FormButton"
                    Text="ZAPISZ"
                    Command="{Binding HandleSubmitBtnCommand}"
                    BackgroundColor="White"
                    TextColor="#1a1a1a"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="45"
                    Margin="0,10,0,0" />

        </VerticalStackLayout>
    </Border>
</mopups:PopupPage>